# This .gitignore file should be placed at the root of your Unity project directory
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
.utmp/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
*.log

# 忽略所有 Unity 生成的 .meta 文件
*.meta

# Blender 相关
*.blend1

# 内存/录制文件
/[Mm]emoryCaptures/
/[Rr]ecordings/

# 编辑器插件
/[Aa]ssets/Plugins/Editor/JetBrains*
*.DotSettings.user

# IDE 缓存
.vs/
.gradle/
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity 崩溃/测试文件
sysinfo.txt
mono_crash.*
crashlytics-build.properties
InitTestScene*.unity*
/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# Addressables 相关
/ServerData
/[Aa]ssets/StreamingAssets/aa*
/[Aa]ssets/AddressableAssetsData/link.xml*
/[Aa]ssets/Addressables_Temp*
/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting 生成文件
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers

# 构建输出
*.apk
*.aab
*.unitypackage
*.app

# ========== 补充通用忽略项 ==========
/[Cc]ache/
/[Pp]ackages-lock.json
/[Tt]emp/UnityLockfile
/.idea/
/.vscode/
*.code-workspace
/[Bb]uildReport/
/[Oo]bj/UnityShaderCompiler/
/[Ll]ibrary/PackageCache/
*.crash
*.dump
/[Dd]iagnostics/
/[Rr]eports/

# ========== 场景专属（按需启用） ==========
# /[Aa]ssets/Plugins/Android/gradle/
# /[Aa]ssets/Plugins/iOS/Pods/
# /[Aa]ssets/Plugins/iOS/Podfile.lock
# /[Tt]estResults/
# /[Pp]rofiler/
# *.trace